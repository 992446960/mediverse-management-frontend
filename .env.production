# 默认：直接打独立 API 域名。Docker 镜像构建时 Dockerfile 会注入 VITE_API_BASE_URL=/api/v1 走 nginx 同域反代（覆盖本行）。
VITE_API_BASE_URL=https://api.mediverse.com/api/v1
# 上传接口返回相对 path 时拼接为此地址（不设则使用 API 同源）
# VITE_FILE_BASE_URL=https://mediverse-management.huaxisy.com
VITE_APP_TITLE=Mediverse Management
VITE_ENABLE_MOCK=false