# 开发时代理 /api 的目标：默认走 vite.config 里的线上域名；本机/局域网后端请写在 .env.development.local（已 gitignore），勿把个人 IP 提交进仓库。
# 示例（复制到 .env.development.local 并取消注释，按你本机改端口）：
# DEV_PROXY_TARGET=http://127.0.0.1:8005
# DEV_PROXY_TARGET=http://192.168.29.22:8005

VITE_API_BASE_URL=/api/v1
# 对接真实 API 时，上传返回相对 path 需拼接为此地址才能回显；Mock 模式下可留空
VITE_FILE_BASE_URL=https://mediverse-management.huaxisy.com
VITE_APP_TITLE=Mediverse Management (Dev)
# 使用线上真实接口（proxy 至 mediverse-management.huaxisy.com）；如需 Mock 改为 true
VITE_ENABLE_MOCK=false